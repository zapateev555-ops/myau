# Переменные для Railway (скопируйте в Variables сервиса)

APP_NAME=МоторДеталь
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:СГЕНЕРИРУЙТЕ_через_php_artisan_key:generate_--show

APP_URL=https://ваш-домен.up.railway.app

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru

# PostgreSQL: добавьте плагин Postgres в проект — DATABASE_URL подставится сам
DB_CONNECTION=pgsql

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

LOG_CHANNEL=stderr
LOG_LEVEL=info
